{
  "name": "bot-lash-designer",
  "version": "1.0.0",
  "description": "WhatsApp AI bot para agendamento de horários em estúdios de lash designer via WAHA + OpenAI",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:env": "tsx scripts/check-env.ts",
    "check:env:prod": "tsx scripts/check-env.ts .env.production",
    "deploy": "powershell -ExecutionPolicy Bypass -File deploy.ps1",
    "reset": "tsx scripts/reset.ts"
  },
  "dependencies": {
    "croner": "^8.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "knex": "^3.1.0",
    "openai": "^4.47.0",
    "sqlite3": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
