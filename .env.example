# Server
PORT=3003

# OpenAI
OPENAI_API_KEY=sk-...

# WAHA (WhatsApp HTTP API) — porta 3011 para não colidir com bot-barbeiro (3001)
WAHA_BASE_URL=http://localhost:3011
WAHA_WEBHOOK_URL=http://host.docker.internal:3003/webhook/waha
WAHA_API_KEY=
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=

# Database
DB_PATH=./data/bot.sqlite

# Webhook security
WEBHOOK_API_KEY=

# Admin dashboard
OWNER_PHONE=
ADMIN_SECRET=
LOG_LEVEL=info
